# Runtime backend
# AGENT_BACKEND=codex  # or claude

# Codex App Server (for AGENT_BACKEND=codex; requires `codex login` using ChatGPT on the host)
# CODEX_APP_SERVER_COMMAND=codex app-server
# CODEX_APPROVAL_POLICY=never
# CODEX_SANDBOX_MODE=workspace-write
# CODEX_RPC_TIMEOUT_SECONDS=120
# CODEX_RPC_STREAM_LIMIT_BYTES=1048576

# Anthropic (for AGENT_BACKEND=claude; optional — if unset, uses OAuth token from ~/.claude/)
# ANTHROPIC_API_KEY=sk-ant-...

# Channels — at least one must be configured

# Telegram (optional — omit to disable)
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# ALLOWED_TELEGRAM_USER_ID=123456789

# Slack (optional — omit to disable)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# ALLOWED_SLACK_USER_ID=U0123456789

# Workspace
WORKSPACE_DIR=workspace

# Timezone (for session resets and cron)
TIMEZONE=Asia/Taipei

# Models (optional)
# CHAT_MODEL=gpt-5.4
# BACKGROUND_MODEL=gpt-5.4

# Logging (optional; powered by loguru)
# LOG_LEVEL=INFO
# LOG_FORMAT={time:YYYY-MM-DD HH:mm:ss.SSS} | {level:<8} | {name}:{function}:{line} - {message}
# LOG_BACKTRACE=false
# LOG_DIAGNOSE=false

# Extra writable roots (optional — comma-separated paths outside WORKSPACE_DIR)
# EXTRA_WRITABLE_ROOTS=/path/to/another/workdir,/path/to/reference-material

# Advanced Google Workspace integration (optional — requires gogcli + `gog auth add`)
# GOG_ACCOUNT=your-google-account@gmail.com
